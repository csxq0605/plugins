[
  {
    "category": "secrets",
    "patterns": [
      {"pattern": "AKIA[0-9A-Z]{16}", "severity": "critical", "description": "AWS Access Key ID", "ref": "CWE-798"},
      {"pattern": "ghp_[A-Za-z0-9]{36}", "severity": "critical", "description": "GitHub Personal Access Token", "ref": "CWE-798"},
      {"pattern": "sk-[A-Za-z0-9]{20,}", "severity": "critical", "description": "OpenAI API Key", "ref": "CWE-798"},
      {"pattern": "sk-ant-[A-Za-z0-9\\-_]{40,}", "severity": "critical", "description": "Anthropic API Key", "ref": "CWE-798"},
      {"pattern": "xoxb-[0-9]{10,13}-[0-9]{10,13}[a-zA-Z0-9]*", "severity": "critical", "description": "Slack Bot Token", "ref": "CWE-798"},
      {"pattern": "sk_live_[0-9a-zA-Z]{24,}", "severity": "critical", "description": "Stripe Live Secret Key", "ref": "CWE-798"},
      {"pattern": "-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----", "severity": "critical", "description": "Private Key", "ref": "CWE-321"},
      {"pattern": "(?i)(password|passwd|pwd)\\s*[:=]\\s*['\"][^'\"]+['\"]", "severity": "critical", "description": "Hardcoded Password", "ref": "CWE-798"}
    ]
  },
  {
    "category": "injection",
    "patterns": [
      {"pattern": "(?i)(SELECT|INSERT|UPDATE|DELETE).{0,100}(\\+|%|f\"|format|concat)", "severity": "critical", "description": "SQL String Concatenation", "ref": "CWE-89"},
      {"pattern": "(?i)innerHTML\\s*=", "severity": "critical", "description": "Direct innerHTML Assignment", "ref": "CWE-79"},
      {"pattern": "(?i)eval\\(", "severity": "critical", "description": "eval() Usage", "ref": "CWE-95"},
      {"pattern": "(?i)exec\\(.{0,50}(\\+|%|f\"|format)", "severity": "critical", "description": "exec with String Formatting", "ref": "CWE-78"},
      {"pattern": "(?i)subprocess\\.(call|run|Popen).{0,100}shell\\s*=\\s*True", "severity": "critical", "description": "subprocess with shell=True", "ref": "CWE-78"},
      {"pattern": "(?i)os\\.system\\(", "severity": "critical", "description": "os.system() Usage", "ref": "CWE-78"},
      {"pattern": "(?i)pickle\\.loads?\\(", "severity": "critical", "description": "Unsafe Deserialization (pickle)", "ref": "CWE-502"},
      {"pattern": "(?i)yaml\\.load\\([^)]*\\)", "severity": "critical", "description": "Unsafe YAML Loading", "ref": "CWE-502"}
    ]
  },
  {
    "category": "auth",
    "patterns": [
      {"pattern": "(?i)jwt\\.verify\\(.{0,50}algorithms?\\s*:\\s*\\[.*none", "severity": "critical", "description": "JWT None Algorithm", "ref": "CWE-327"},
      {"pattern": "(?i)password.{0,20}(md5|sha1)", "severity": "critical", "description": "Weak Password Hashing", "ref": "CWE-328"},
      {"pattern": "(?i)session.{0,20}(secure\\s*:\\s*false|httpOnly\\s*:\\s*false)", "severity": "high", "description": "Insecure Cookie Configuration", "ref": "CWE-614"},
      {"pattern": "(?i)cors.{0,20}(origin\\s*:\\s*['\"]?\\*|allow.?all)", "severity": "high", "description": "CORS Allow All Origins", "ref": "CWE-942"}
    ]
  },
  {
    "category": "config",
    "patterns": [
      {"pattern": "(?i)debug\\s*[:=]\\s*true", "severity": "high", "description": "Debug Mode Enabled", "ref": "CWE-489"},
      {"pattern": "(?i)DEBUG\\s*=\\s*True", "severity": "high", "description": "Django DEBUG Mode", "ref": "CWE-489"},
      {"pattern": "(?i)SSL_VERIFY\\s*=\\s*False", "severity": "high", "description": "SSL Verification Disabled", "ref": "CWE-295"},
      {"pattern": "(?i)verify\\s*=\\s*False", "severity": "medium", "description": "requests verify=False", "ref": "CWE-295"}
    ]
  },
  {
    "category": "ai_specific",
    "patterns": [
      {"pattern": "(?i)(openai|anthropic|gemini).{0,20}(api.?key|secret)", "severity": "critical", "description": "AI API Key Reference", "ref": "CWE-798"},
      {"pattern": "(?i)(execute|eval|run|exec).{0,50}(llm|ai|model|gpt|claude).{0,50}(output|response|result)", "severity": "critical", "description": "Executing LLM Output", "ref": "CWE-95"},
      {"pattern": "(?i)system.{0,50}(ignore|forget|override).{0,50}(previous|above|instructions)", "severity": "high", "description": "Prompt Injection Vector", "ref": "CWE-77"}
    ]
  }
]
